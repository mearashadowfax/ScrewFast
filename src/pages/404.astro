---
// Import section components
import MainLayout from '@/layouts/MainLayout.astro';
import Btn404 from '@components/ui/buttons/Btn404.astro';
import { SITE } from '@data/constants';

// Define types for translations
type TranslationKeys = 'en' | 'fr';
type Translations = {
  [key in TranslationKeys]: {
    pageTitle: string;
    subTitle: string;
    content: string;
    homeTitle: string;
    backTitle: string;
  };
};

// Define variables for page content
const defaultLang: TranslationKeys = 'en';
const translations: Translations = {
  en: {
    pageTitle: `Page Not Found | ${SITE.title}`,
    subTitle: "Oops, this isn't the tool you were looking for!",
    content:
      "Don't let this hiccup slow you down. Let's get you back to building your masterpiece.",
    homeTitle: 'Go Home',
    backTitle: 'Go Back',
  },
  fr: {
    pageTitle: `Page Non Trouvée | ${SITE.title}`,
    subTitle: "Oops, ce n'est pas l'outil que vous recherchiez!",
    content:
      "Ne laissez pas ce contretemps vous ralentir. Revenons à la construction de votre chef-d'œuvre.",
    homeTitle: "Page d'accueil",
    backTitle: 'Retour',
  },
};

// Determine language from the URL (/fr or /fr/...)
const urlPath = Astro.url.pathname;
const lang: TranslationKeys = /^\/fr(\/|$)/.test(urlPath) ? 'fr' : defaultLang;
const homeHref = lang === 'fr' ? '/fr' : '/';

const { pageTitle, subTitle, content, homeTitle, backTitle } =
  translations[lang];
---

<MainLayout title={pageTitle} lang={lang} hideFooter>
  <section class="min-h-[calc(100svh-5.5rem)]" aria-labelledby="subtitle">
    <div
      class="pointer-events-none fixed inset-0 z-10 grid place-content-center px-4"
    >
      <div
        class="pointer-events-auto mx-auto max-w-(--breakpoint-sm) text-center"
      >
        <h1
          class="text-dark mb-4 text-7xl font-extrabold text-yellow-500 lg:text-9xl dark:text-yellow-400"
        >
          404
        </h1>
        <p
          id="subtitle"
          class="mb-4 text-3xl font-bold tracking-tight text-balance text-neutral-700 md:text-4xl dark:text-neutral-300"
        >
          {subTitle}
        </p>
        <p
          id="content"
          class="mb-4 text-lg text-pretty text-neutral-600 dark:text-neutral-400"
        >
          {content}
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href={homeHref}
            class="group inline-flex items-center justify-center gap-x-2 rounded-lg border border-transparent bg-yellow-400 px-4 py-3 text-sm font-bold text-neutral-800 ring-zinc-500 outline-hidden transition duration-300 hover:bg-yellow-500 focus-visible:ring-3 2xl:text-base dark:ring-zinc-200"
          >
            {homeTitle}
          </a>
          <Btn404 title={backTitle} id="go-back" />
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const goBackButton = document.getElementById('go-back');
  goBackButton?.addEventListener('click', () => {
    if (window.history.length > 1) {
      history.back();
    } else {
      window.location.href = '/';
    }
  });
</script>
