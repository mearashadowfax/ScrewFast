---
import { Image } from 'astro:assets';

const { src, alt, loading = 'lazy' } = Astro.props;

interface Props {
  src: string;
  alt: string;
  loading?: 'lazy' | 'eager';
}
---

<Image
  class="inline-block size-8 shrink-0 rounded-full ring-2 ring-neutral-50 dark:ring-zinc-800"
  src={src}
  alt={alt}
  width={32}
  height={32}
  loading={loading}
  decoding="async"
/>
